## Read-only client — used by the MCP server (genesys_mcp.server).
## OAuth client must have only *:readonly scopes.
GENESYS_CLIENT_ID=your-client-credentials-client-id
GENESYS_CLIENT_SECRET=your-client-credentials-secret
GENESYS_REGION=ap-southeast-2

## Write-scoped client — used ONLY by scripts/provision_users.py (bulk
## agent provisioning). Do NOT set these in the same shell that runs the MCP
## server — the MCP intentionally never loads them. Paste them into a
## separate file (e.g. .env.write, gitignored by the .env.* pattern) or
## export them in the shell where you run the provisioning script.
#
# GENESYS_WRITE_CLIENT_ID=your-write-client-id
# GENESYS_WRITE_CLIENT_SECRET=your-write-client-secret
